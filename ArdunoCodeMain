/* CALIBRATION */

float calibration_factor = -1062511.17259;

/* PRODUCT STRUCT */

struct Product{
  String id;
  String name;
  float weight;
  int perBox;
  float tare;
  int low;
};

Product products[20];

int productCount=0;
int currentProduct=0;

/* SAVE CONTROL */

float lastWeight=0;
bool dataSaved=false;
unsigned long stableTimer=0;

/* WIFI CONNECT */

void connectWiFi(){

  Serial.println("Connecting WiFi...");

  WiFi.begin(ssid,pass);

  int retry = 0;                                      // ✅ แก้ไข #1: กันค้างตอน WiFi ต่อไม่ได้
  while(WiFi.status()!=WL_CONNECTED){
    delay(500);
    Serial.print(".");
    retry++;
    if(retry > 20){                                   // รอสูงสุด 10 วินาที
      Serial.println("\nWiFi Failed! Restarting...");
      ESP.restart();
    }
  }

  Serial.println("\nWiFi Connected");

}

/* GET PRODUCT */

void getProducts(){

  Serial.println("Requesting product list...");

  HTTPClient http;
  http.setTimeout(15000);                             // ✅ แก้ไข #2: เพิ่ม timeout เป็น 15 วินาที

  String url=GAS_URL+"?mode=product";

  http.begin(url);
  http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);

  int httpCode=http.GET();

  Serial.print("HTTP Code: ");                        // ✅ แก้ไข #3: เพิ่ม log ดู response
  Serial.println(httpCode);

  if(httpCode==200){

    String payload=http.getString();

    Serial.println("Payload: "+payload);              // ดูว่าได้ข้อมูลอะไรกลับมา

    StaticJsonDocument<2048> doc;
    deserializeJson(doc,payload);

    productCount=doc.size();

    for(int i=0;i<productCount;i++){

      products[i].id=doc[i]["id"].as<String>();
      products[i].name=doc[i]["name"].as<String>();
      products[i].weight = doc[i]["weight"].as<float>();
      products[i].perBox = doc[i]["perbox"].as<int>();
      products[i].tare   = doc[i]["tare"].as<float>();
      products[i].low    = doc[i]["low"].as<int>();

      Serial.println("----- PRODUCT LOADED -----");
      Serial.print("Name: ");
      Serial.println(products[i].name);
      Serial.print("Weight: ");
      Serial.println(products[i].weight);
      Serial.print("Tare: ");
      Serial.println(products[i].tare);
      Serial.print("Low: ");
      Serial.println(products[i].low);

    }

  } else {
    Serial.print("HTTP Error: ");                     // ✅ แก้ไข #3: แสดง error แทน crash
    Serial.println(httpCode);
    Serial.println("Cannot load products, productCount = 0");
    productCount = 0;                                 // ป้องกัน crash ถ้าโหลดไม่ได้
  }

  http.end();

}

/* SEND DATA */

void sendData(float weight,int qty,String status){

  HTTPClient http;

  http.begin(GAS_URL);

  http.addHeader("Content-Type","application/json");

  float weight_g=weight;
  float weight_kg=weight/1000;

  String json=
  "{"
  "\"mode\":\"save\","
  "\"product_id\":\""+products[currentProduct].id+"\","
  "\"name\":\""+products[currentProduct].name+"\","
  "\"weight_kg\":"+String(weight_kg)+","
  "\"weight_g\":"+String(weight_g)+","
  "\"qty\":"+String(qty)+","
  "\"status\":\""+status+"\""
  "}";

  Serial.println(json);

  http.POST(json);

  http.end();

}

/* BLYNK SELECT PRODUCT */

BLYNK_WRITE(V5){

  int index = param.asInt();

  if(index < productCount){
    currentProduct = index;
    Serial.print("Switch Product: ");
    Serial.println(products[currentProduct].name);
  }

}

/* REFRESH PRODUCT */

BLYNK_WRITE(V6){

  getProducts();
  Serial.println("Product List Refreshed");

}

/* SETUP */

void setup(){

  Serial.begin(115200);

  lcd.init();
  lcd.backlight();

  scale.begin(DT,SCK);
  scale.set_scale(calibration_factor);

  delay(2000);

  scale.tare();

  Serial.println("Scale Ready");

  connectWiFi();

  delay(1000);                                        // ✅ แก้ไข #4: รอ WiFi เสถียรก่อนดึงข้อมูล

  getProducts();

  /* BLYNK */

  Blynk.config(BLYNK_AUTH_TOKEN);
  Blynk.connect();

  delay(500);                                         // ✅ แก้ไข #4: รอ Blynk เชื่อมต่อเสถียร

}

/* LOOP */

void loop(){

  Blynk.run();

  if(productCount==0) return;

  /* READ WEIGHT */

  if (!scale.is_ready()) {
    Serial.println("HX711 not ready");
    return;
  }

  float totalWeight = scale.get_units(20)*1000.0;

  float weight = totalWeight - products[currentProduct].tare;

  if(weight < 0.1) weight = 0;

  float perItem = products[currentProduct].weight;

  if(perItem <= 0){
    Serial.println("ERROR: product weight = 0");
    return;
  }

  int qty = weight / perItem;

  Serial.print("Weight:");
  Serial.print(weight);
  Serial.print(" Qty:");
  Serial.println(qty);

  /* STATUS */

  String status="NORMAL";

  if(qty<products[currentProduct].low){
    status="LOW STOCK";
  }

  /* LCD */

  lcd.setCursor(0,0);
  lcd.print(products[currentProduct].name);
  lcd.print("      ");

  lcd.setCursor(0,1);

  if(status=="LOW STOCK"){
    lcd.print("LOW ");
    lcd.print(qty);
    lcd.print(" pcs   ");
  }else{
    lcd.print(qty);
    lcd.print(" pcs   ");
  }

  /* BLYNK */

  Blynk.virtualWrite(V0,qty);
  Blynk.virtualWrite(V1,weight);

  if(status=="LOW STOCK"){
    Blynk.virtualWrite(V3,1);
  }else{
    Blynk.virtualWrite(V3,0);
  }

  /* AUTO SAVE */

  if(abs(weight-lastWeight)<2){

    if(millis()-stableTimer>5000 && dataSaved==false){

      if(qty>0){

        sendData(weight,qty,status);

        dataSaved=true;

        Serial.println("DATA SAVED");

      }

    }

  }else{

    stableTimer=millis();
    dataSaved=false;

  }

  lastWeight=weight;

  delay(500);

}
