/* ========================= */
/* API */
/* ========================= */

function doPost(e){

  try{
    var data = JSON.parse(e.postData.contents);
  }catch(err){
    return ContentService.createTextOutput("Invalid JSON");
  }

  /* LINE */
  if(data.events){
    var text = data.events[0].message.text;
    var replyToken = data.events[0].replyToken;

    var result = processCommand(text);
    replyLine(replyToken,result);

    return ContentService.createTextOutput("OK");
  }

  /* ESP32 */
  if(data.mode=="save"){
    return saveData(data);
  }

  return ContentService.createTextOutput("NO ACTION");
}
function doGet(e) {
  var mode = e.parameter.mode;

  if (mode == "product") {
    return getProductList();
  }

  return ContentService.createTextOutput("NO ACTION");
}

function getProductList() {
  var sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName("Product");
  var data = sheet.getDataRange().getValues();

  var products = [];

  for (var i = 1; i < data.length; i++) {
    products.push({
      id:      data[i][0],
      name:    data[i][1],
      weight:  data[i][2],
      perbox:  data[i][3],
      tare:    data[i][4],
      low:     data[i][5]
    });
  }

  return ContentService
    .createTextOutput(JSON.stringify(products))
    .setMimeType(ContentService.MimeType.JSON);
}
