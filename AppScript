/* ========================= */
/* GET LOW */
/* ========================= */

function getLowStock(product_id){

  var sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName("Product");
  var data = sheet.getDataRange().getValues();

  for(var i=1;i<data.length;i++){
    if(data[i][0]==product_id){
      return data[i][5];
    }
  }

  return 0;
}

/* ========================= */
/* COMMAND */
/* ========================= */

function processCommand(text){

  text = text.toLowerCase().trim();

  if(text=="stock"){
    return getAllStock();
  }

  return getStock(text);
}

/* ========================= */

function getStock(product){

  var sheet=SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName("DATA");
  var data=sheet.getDataRange().getValues();

  var latest=null;

  for(var i=1;i<data.length;i++){

    if(data[i][2].toString().toLowerCase()==product){

      if(!latest || data[i][0] > latest.time){
        latest = {
          qty:data[i][5],
          time:data[i][0]
        };
      }

    }
  }

  if(latest){
    return "📦 "+product+"\nเหลือ "+latest.qty+" ชิ้น";
  }

  return "❌ ไม่พบสินค้า";
}

/* ========================= */

function getAllStock(){

  var sheet=SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName("DATA");
  var data=sheet.getDataRange().getValues();

  var list={};

  for(var i=1;i<data.length;i++){

    var name = data[i][2];
    var time = data[i][0];

    if(!list[name] || time > list[name].time){
      list[name] = {
        qty:data[i][5],
        time:time
      };
    }
  }

  var msg="📦 Inventory\n\n";

  for(var key in list){
    msg += key+" : "+list[key].qty+" ชิ้น\n";
  }

  return msg;
}

/* ========================= */

function sendLine(message){

  UrlFetchApp.fetch("https://api.line.me/v2/bot/message/push",{
    method:"post",
    headers:{
      "Content-Type":"application/json",
      "Authorization":"Bearer "+CHANNEL_ACCESS_TOKEN
    },
    payload:JSON.stringify({
      to:USER_ID,
      messages:[{type:"text",text:message}]
    })
  });

}

/* ========================= */

function replyLine(token,message){

  UrlFetchApp.fetch("https://api.line.me/v2/bot/message/reply",{
    method:"post",
    headers:{
      "Content-Type":"application/json",
      "Authorization":"Bearer "+CHANNEL_ACCESS_TOKEN
    },
    payload:JSON.stringify({
      replyToken:token,
      messages:[{type:"text",text:message}]
    })
  });

}
/* 👇 วางตรงนี้เลย */

function sendDailyReport(){

  var msg = getAllStock();

  sendLine("📊 รายงานสต็อกล่าสุด\n\n"+msg);

}
